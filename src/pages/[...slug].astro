---
import Layout from "../components/Layout.astro";
import Article from "../components/Article.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: entry,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

const postUrl = new URL(`/${post.id}`, Astro.site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "url": postUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl,
  },
  "author": {
    "@type": "Organisation",
    "name": "Asindu Drileba",
    "url": "https://asindu.xyz",
  },
  "publisher": {
    "@type": "Organisation",
    "name": "Asindu Drileba",
    "url": "https://asindu.xyz",
  },
};
---

<Layout title={`${post.data.title} — The Black Epicure`} description={post.data.description} ogType="article">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Article title={post.data.title} date={post.data.date} description={post.data.description}>
    <Content />
  </Article>
</Layout>
