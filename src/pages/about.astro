---
import Layout         from "../components/Layout.astro";
import PageLayout     from "../components/PageLayout.astro";
import * as aboutPage from '../content/about.md';

const page_content  = await aboutPage.compiledContent();
const postUrl       = new URL(`/about`, Astro.site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": aboutPage.frontmatter.title,
  "description": aboutPage.frontmatter.description,
  "datePublished": (new Date()).toISOString(),
  "url": postUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl,
  },
  "author": {
    "@type": "Organisation",
    "name": "Asindu Drileba",
    "url": "https://asindu.xyz",
  },
  "publisher": {
    "@type": "Organisation",
    "name": "Asindu Drileba",
    "url": "https://asindu.xyz",
  },
};
---

<Layout title={aboutPage.frontmatter.title} description={aboutPage.frontmatter.description} ogType="article">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <PageLayout title={aboutPage.frontmatter.title} date={(new Date())} description={aboutPage.frontmatter.description}>
    <div set:html={page_content} />
  </PageLayout>
</Layout>
